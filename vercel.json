{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/((?!api|uploads|assets|test.html|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
